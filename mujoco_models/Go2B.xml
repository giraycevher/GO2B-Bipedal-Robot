<?xml version="1.0" ?>
<mujoco model="12dof_rev_1_0_fixed">

  <compiler angle="radian"/>
  <option integrator="implicitfast" timestep="0.001" gravity="0 0 -9.81"/>

  <default>
    <default class="go2b">
      <joint armature="0.01" damping="0.5" frictionloss="0.1"/>
      <motor ctrllimited="true" ctrlrange="-4 4"/>
      <position ctrllimited="true" ctrlrange="-4 4" kp="1000" kv="50"/>

      <default class="visual">
        <geom type="box" contype="0" conaffinity="0" mass="0.064" rgba="0.2 0.2 0.2 1"/>
      </default>

      <default class="bracket">
        <geom type="capsule" contype="0" conaffinity="0" mass="0.03" rgba="0.6 0.65 0.7 1"/>
      </default>

      <default class="collision">
        <geom type="box" friction="2.0 0.5 0.001" condim="3" contype="1" conaffinity="1"/>
      </default>
    </default>
  </default>

<asset>
    <texture
        type="skybox"
        builtin="gradient"
        rgb1="0.3 0.5 0.7"
        rgb2="0 0 0"
        width="512"
        height="3072"/>

    <texture
        name="groundplane"
        type="2d"
        builtin="checker"
        rgb1="0.25 0.25 0.25"
        rgb2="0.15 0.15 0.15"
        width="512"
        height="512"/>

    <material
        name="groundplane"
        texture="groundplane"
        texrepeat="20 20"
        reflectance="0.1"/>
</asset>



  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" directional="true" diffuse="0.8 0.8 0.8"/>
      <geom
    name="floor"
    type="plane"
    pos="0 0 0"
    size="20 20 0.1"
    material="groundplane"/>

    <body name="torso" pos="0 0 0.6" quat="1 0 0 0" childclass="go2b">
      <freejoint name="floating_base_joint"/>
      <geom class="visual" name="torso_geom" size="0.05 0.08 0.05" mass="1.3" rgba="0.2 0.6 0.8 1"/>

      <geom class="bracket" name="pelvis_bridge" fromto="0 0.055 -0.05  0 -0.055 -0.05" size="0.015"/>
      <geom class="bracket" name="torso_to_pelvis" fromto="0 0 0  0 0 -0.05" size="0.015"/>
      <site name="imu_site" pos="0 0 0" size="0.01"/>

      <body name="left_hip_yaw_link" pos="0 0.055 -0.05">
        <joint name="left_hip_yaw_joint" axis="0 0 1" range="-0.5 0.5"/>
        <geom class="visual" name="l_yaw_motor" size="0.02 0.02 0.01" pos="0 0.025 0"/>
        <geom class="bracket" name="l_yaw_bridge" fromto="0 0 0  0 0.025 0" size="0.01"/>

        <body name="left_hip_roll_link" pos="0 0 0">
          <joint name="left_hip_roll_joint" axis="1 0 0" range="-0.6 0.6"/>
          <geom class="visual" name="l_roll_motor" size="0.02 0.01 0.02" pos="0 0 0.03" euler="0 1.5708 0"/>
          <geom class="bracket" name="l_roll_bridge" fromto="0 0 0  0 0 0.03" size="0.01"/>

          <body name="left_hip_pitch_link" pos="0 0 0">
            <joint name="left_hip_pitch_joint" axis="0 1 0" range="-2.0 2.0"/>
            <geom class="visual" name="l_pitch_motor" size="0.01 0.02 0.02" pos="0.03 0 0" euler="1.5708 0 0"/>
            <geom class="bracket" name="l_pitch_bridge" fromto="0 0 0  0.03 0 0" size="0.01"/>

            <geom class="bracket" name="l_thigh" fromto="0 0 0  0 0 -0.20" size="0.015" mass="0.5"/>

            <body name="left_knee_link" pos="0 0 -0.20">
              <joint name="left_knee_joint" axis="0 1 0" range="-0.1 2.8"/>
              <geom class="visual" name="l_knee_motor" size="0.01 0.02 0.02" pos="0.03 0 0" euler="1.5708 0 0"/>
              <geom class="bracket" name="l_knee_bridge" fromto="0 0 0  0.03 0 0" size="0.01"/>

              <geom class="bracket" name="l_calf" fromto="0 0 0  0 0 -0.20" size="0.015" mass="0.5"/>

              <body name="left_ankle_pitch_link" pos="0 0 -0.20">
                <joint name="left_ankle_pitch_joint" axis="0 1 0" range="-2.0 2.0"/>
                <geom class="visual" name="l_ankle_pitch_motor" size="0.01 0.02 0.02" pos="0.03 0 0" euler="1.5708 0 0"/>
                <geom class="bracket" name="l_ap_bridge" fromto="0 0 0  0.03 0 0" size="0.01"/>

                <body name="left_ankle_roll_link" pos="0 0 0">
                  <joint name="left_ankle_roll_joint" axis="1 0 0" range="-0.6 0.6"/>
                  <geom class="visual" name="l_ankle_roll_motor" size="0.02 0.01 0.02" pos="0 0 0.03" euler="0 1.5708 0"/>
                  <geom class="bracket" name="l_ar_bridge" fromto="0 0 0  0 0 0.03" size="0.01"/>
                  <geom class="bracket" name="l_foot_bridge" fromto="0 0 0  0 0 -0.05" size="0.01"/>

                  <body name="left_foot" pos="0 0 -0.05">
                    <geom class="collision" name="l_foot_geom" size="0.06 0.04 0.01" pos="0 0 0" mass="0.2" rgba="0.5 0.8 0.5 1"/>
                    <site name="foot_L_site" size="0.06 0.04 0.005" pos="0 0 -0.01" rgba="1 0 0 0"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>

      <body name="right_hip_yaw_link" pos="0 -0.055 -0.05">
        <joint name="right_hip_yaw_joint" axis="0 0 1" range="-0.5 0.5"/>
        <geom class="visual" name="r_yaw_motor" size="0.02 0.02 0.01" pos="0 -0.025 0"/>
        <geom class="bracket" name="r_yaw_bridge" fromto="0 0 0  0 -0.025 0" size="0.01"/>

        <body name="right_hip_roll_link" pos="0 0 0">
          <joint name="right_hip_roll_joint" axis="1 0 0" range="-0.6 0.6"/>
          <geom class="visual" name="r_roll_motor" size="0.02 0.01 0.02" pos="0 0 0.03" euler="0 1.5708 0"/>
          <geom class="bracket" name="r_roll_bridge" fromto="0 0 0  0 0 0.03" size="0.01"/>

          <body name="right_hip_pitch_link" pos="0 0 0">
            <joint name="right_hip_pitch_joint" axis="0 1 0" range="-2.0 2.0"/>
            <geom class="visual" name="r_pitch_motor" size="0.01 0.02 0.02" pos="0.03 0 0" euler="1.5708 0 0"/>
            <geom class="bracket" name="r_pitch_bridge" fromto="0 0 0  0.03 0 0" size="0.01"/>

            <geom class="bracket" name="r_thigh" fromto="0 0 0  0 0 -0.20" size="0.015" mass="0.5"/>

            <body name="right_knee_link" pos="0 0 -0.20">
              <joint name="right_knee_joint" axis="0 1 0" range="-0.1 2.8"/>
              <geom class="visual" name="r_knee_motor" size="0.01 0.02 0.02" pos="0.03 0 0" euler="1.5708 0 0"/>
              <geom class="bracket" name="r_knee_bridge" fromto="0 0 0  0.03 0 0" size="0.01"/>

              <geom class="bracket" name="r_calf" fromto="0 0 0  0 0 -0.20" size="0.015" mass="0.5"/>

              <body name="right_ankle_pitch_link" pos="0 0 -0.20">
                <joint name="right_ankle_pitch_joint" axis="0 1 0" range="-2.0 2.0"/>
                <geom class="visual" name="r_ankle_pitch_motor" size="0.01 0.02 0.02" pos="0.03 0 0" euler="1.5708 0 0"/>
                <geom class="bracket" name="r_ap_bridge" fromto="0 0 0  0.03 0 0" size="0.01"/>

                <body name="right_ankle_roll_link" pos="0 0 0">
                  <joint name="right_ankle_roll_joint" axis="1 0 0" range="-0.6 0.6"/>
                  <geom class="visual" name="r_ankle_roll_motor" size="0.02 0.01 0.02" pos="0 0 0.03" euler="0 1.5708 0"/>
                  <geom class="bracket" name="r_ar_bridge" fromto="0 0 0  0 0 0.03" size="0.01"/>
                  <geom class="bracket" name="r_foot_bridge" fromto="0 0 0  0 0 -0.05" size="0.01"/>

                  <body name="right_foot" pos="0 0 -0.05">
                    <geom class="collision" name="r_foot_geom" size="0.06 0.04 0.01" pos="0 0 0" mass="0.2" rgba="0.5 0.8 0.5 1"/>
                    <site name="foot_R_site" size="0.06 0.04 0.005" pos="0 0 -0.01" rgba="1 0 0 0"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>

    </body>
  </worldbody>

  <sensor>
    <framepos name="com_pos" objtype="site" objname="imu_site"/>
    <touch name="touch_L" site="foot_L_site"/>
    <touch name="touch_R" site="foot_R_site"/>
  </sensor>

  <actuator>
    <position class="go2b" name="left_hip_yaw_joint"     joint="left_hip_yaw_joint"/>
    <position class="go2b" name="left_hip_roll_joint"    joint="left_hip_roll_joint"/>
    <position class="go2b" name="left_hip_pitch_joint"   joint="left_hip_pitch_joint"/>
    <position class="go2b" name="left_knee_joint"        joint="left_knee_joint"/>
    <position class="go2b" name="left_ankle_pitch_joint" joint="left_ankle_pitch_joint"/>
    <position class="go2b" name="left_ankle_roll_joint"  joint="left_ankle_roll_joint"/>

    <position class="go2b" name="right_hip_yaw_joint"     joint="right_hip_yaw_joint"/>
    <position class="go2b" name="right_hip_roll_joint"    joint="right_hip_roll_joint"/>
    <position class="go2b" name="right_hip_pitch_joint"   joint="right_hip_pitch_joint"/>
    <position class="go2b" name="right_knee_joint"        joint="right_knee_joint"/>
    <position class="go2b" name="right_ankle_pitch_joint" joint="right_ankle_pitch_joint"/>
    <position class="go2b" name="right_ankle_roll_joint"  joint="right_ankle_roll_joint"/>
  </actuator>




</mujoco>
