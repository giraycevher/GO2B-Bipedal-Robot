import mujoco
import mujoco.viewer
import numpy as np
import time
import math
import json
import matplotlib.pyplot as plt
from PIL import Image

from google import genai

from robot_utils import DynamicStepPlanner
from kinematic import IK_leg
from preview_control import init_preview_control


API_KEY = ""
client = genai.Client(api_key=API_KEY)

# --- Load MuJoCo Model ---
model = mujoco.MjModel.from_xml_path("robot.xml")
data = mujoco.MjData(model)

A_leg, B_leg = 0.2, 0.2
dt_mpc = 0.01
z_c = 0.33
N_preview = 100

STEP_DURATION = 80
STARTUP_DELAY = 100  # Physics Fix 1: Delay for the robot to squat and stabilize at the start
STEP_HEIGHT = 0.04
MAX_SIM_TIME = 15.0
dx = 0.08
D_left, D_right = 0.05, -0.05

# 2. ROUTE PLANNING WITH GEMINI (VISION LANGUAGE MODEL)
print("Gemini is analyzing the environment and planning the route. Please wait (2-4s)...")

mujoco.mj_forward(model, data)
renderer = mujoco.Renderer(model, height=480, width=640)
renderer.update_scene(data)
img_array = renderer.render()
first_frame_image = Image.fromarray(img_array)
renderer.close()

system_prompt = """
You are the autonomous navigation brain of a bipedal robot.
I am giving you a camera image from the robot's starting position.
Your task: Plan a safe 8-step walking route (waypoints) going forward.
Rule 1: Steps must alternate in the Y axis between right (-0.05) and left (0.05).
Rule 2: The robot must move approximately 0.08 meters forward in the X axis per step.
Rule 3: Z value is the MPC push/timing parameter. Use 0.0 for the first step, around 5.0 and 10.0 for others.

Please respond ONLY in the following valid JSON format:
[
  {"x": 0.00, "y": 0.05, "z": 0.0},
  {"x": 0.08, "y": -0.05, "z": 5.0}
]
"""

try:
    response = client.models.generate_content(
        model='gemini-2.5-flash',
        contents=[first_frame_image, system_prompt]
    )

    response_text = response.text.replace('```json', '').replace('```', '').strip()
    gemini_steps = json.loads(response_text)

    footstep_list = []
    for step in gemini_steps:
        footstep_list.append([step["x"], step["y"], step["z"]])

    footstep = np.array(footstep_list)
    print("✅ Gemini Route Planning Successful! Target Steps:")
    print(footstep)

except Exception as e:
    print(f"❌ Gemini API Error: {e}")
    print("Falling back to default manual route...")
    footstep = np.array([
        [0.00, D_left, 0.0],
        [dx, D_right, 5.0],
        [dx * 2, D_left, 5.0],
        [dx * 3, D_right, 10.0],
        [dx * 4, D_left, 10.0],
        [dx * 5, D_right, 10.0],
        [dx * 6, D_left, 10.0],
        [dx * 7, D_right, 10.0]
    ])

# 3. INITIALIZE CONTROLLER AND PLANNER
Ks, Kx, F_preview, sys_A, sys_B, sys_C = init_preview_control(dt_mpc, z_c, N_preview)
planner = DynamicStepPlanner(footstep, STEP_DURATION, STARTUP_DELAY)

log_t = []
log_real_com_x = []
log_real_com_y = []
log_planned_com_x = []
log_planned_com_y = []

state_x = np.zeros((3, 1))
state_y = np.zeros((3, 1))

# 4. MAIN SIMULATION LOOP
print("Simulation started...")
with mujoco.viewer.launch_passive(model, data) as viewer:
    step_index = 0

    # Physics Fix 2: Time synchronization ratio (typically 10)
    sim_step_multiplier = max(1, int(dt_mpc / model.opt.timestep))

    while data.time < MAX_SIM_TIME and viewer.is_running():
        step_start = time.time()
        t = data.time

        if 9.0 <= t <= 9.1:
            data.qfrc_applied[0] = 30.0
        else:
            data.qfrc_applied[0] = 0.0

        # --- MPC Computation ---
        p_ref_x_window = np.zeros(N_preview)
        p_ref_y_window = np.zeros(N_preview)

        for k in range(N_preview):
            idx = step_index + k
            if idx < len(planner.p_ref_x):
                p_ref_x_window[k] = planner.p_ref_x[idx]
                p_ref_y_window[k] = planner.p_ref_y[idx]
            else:
                p_ref_x_window[k] = planner.p_ref_x[-1]
                p_ref_y_window[k] = planner.p_ref_y[-1]

        px = sys_C @ state_x
        py = sys_C @ state_y

        e_x = float(px[0, 0] - p_ref_x_window[0])
        e_y = float(py[0, 0] - p_ref_y_window[0])

        kx_state_x = (Kx @ state_x).item() if (Kx @ state_x).size == 1 else (Kx @ state_x)[0]
        kx_state_y = (Kx @ state_y).item() if (Kx @ state_y).size == 1 else (Kx @ state_y)[0]

        u_x_val = -Ks * e_x - kx_state_x + float(np.sum(F_preview * p_ref_x_window))
        u_y_val = -Ks * e_y - kx_state_y + float(np.sum(F_preview * p_ref_y_window))

        state_x = sys_A @ state_x + sys_B * float(u_x_val)
        state_y = sys_A @ state_y + sys_B * float(u_y_val)

        CoM_x = float(state_x[0, 0])
        CoM_y = float(state_y[0, 0])

        # --- Inverse Kinematics (IK) and Smooth Squat ---
        target_L_x, target_L_y, is_left = planner.swing_target(step_index, state_x, state_y)
        target_L_x = float(np.ravel(target_L_x)[0])
        target_L_y = float(np.ravel(target_L_y)[0])

        # Physics Fix 1: Gradually lower the CoM from 0.40 m to z_c (0.33 m)
        if step_index < STARTUP_DELAY:
            current_z = 0.40 - (0.40 - z_c) * (step_index / float(STARTUP_DELAY))
        else:
            current_z = z_c

        swing_z = 0.0
        real_step = step_index - STARTUP_DELAY
        if real_step >= 0:
            phase = real_step % STEP_DURATION
            swing_z = STEP_HEIGHT * math.sin(math.pi * phase / STEP_DURATION)

        L_z = current_z - (swing_z if is_left else 0.0)
        R_z = current_z - (0.0 if is_left else swing_z)

        Foot_R = np.eye(3)
        Body_p = np.array([CoM_x, CoM_y, current_z])
        Body_R = np.eye(3)

        Foot_p_L = np.array([target_L_x, target_L_y, current_z - L_z], dtype=float)
        Foot_p_R = np.array([CoM_x, CoM_y - D_right, current_z - R_z], dtype=float)

        try:
            q_L = IK_leg(Body_p, Body_R, D_left, A_leg, B_leg, Foot_p_L, Foot_R)
            q_R = IK_leg(Body_p, Body_R, D_right, A_leg, B_leg, Foot_p_R, Foot_R)

            data.ctrl[0:6] = q_R
            data.ctrl[6:12] = q_L
        except Exception:
            pass

        # Physics Fix 2: Synchronize MPC dt with MuJoCo timestep
        for _ in range(sim_step_multiplier):
            mujoco.mj_step(model, data)

        viewer.sync()
        step_index += 1

        # --- Data Logging ---
        log_t.append(t)
        try:
            real_com_x = data.sensor('com_pos').data[0]
            real_com_y = data.sensor('com_pos').data[1]
            log_real_com_x.append(real_com_x)
            log_real_com_y.append(real_com_y)
        except Exception:
            log_real_com_x.append(0)
            log_real_com_y.append(0)

        log_planned_com_x.append(CoM_x)
        log_planned_com_y.append(CoM_y)

        # Real-time visualization speed control
        time_until_next_step = dt_mpc - (time.time() - step_start)
        if time_until_next_step > 0:
            time.sleep(time_until_next_step)

# 5. END OF SIMULATION: PLOT RESULTS
print("Simulation completed. Generating plots for the paper...")

plt.figure(figsize=(12, 6))
plt.subplot(2, 1, 1)
plt.plot(log_t, log_planned_com_x, label="Planned CoM X (MPC)", linestyle="--", color="blue")
plt.plot(log_t, log_real_com_x, label="Real CoM X (Sensor)", linewidth=2, color="red")
plt.axvline(x=9.0, color='black', linestyle=':', label='Push Moment')
plt.title("X-Axis VLA+MPC Reference Tracking and Push Recovery")
plt.xlabel("Time (s)")
plt.ylabel("X Position (m)")
plt.legend()
plt.grid(True)

plt.subplot(2, 1, 2)
plt.plot(log_t, log_planned_com_y, label="Planned CoM Y (MPC)", linestyle="--", color="blue")
plt.plot(log_t, log_real_com_y, label="Real CoM Y (Sensor)", linewidth=2, color="red")
plt.axvline(x=9.0, color='black', linestyle=':', label='Push Moment')
plt.title("Y-Axis Lateral Oscillation (ZMP) and Balance")
plt.xlabel("Time (s)")
plt.ylabel("Y Position (m)")
plt.legend()
plt.grid(True)

plt.tight_layout()
plt.show()
